{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "declaration": false,
    "incremental": false,
    "isolatedModules": false,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": false,
    "outDir": "dist-worker",
    "rootDir": "src",
    "target": "ES2022"
  },
  "include": [
    "src/lib/**/*.ts",
    "src/worker/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
